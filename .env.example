# =============================================================================
# GoJohnny — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_ENV=development           # development | staging | production
APP_DEBUG=true                # true apenas em development
APP_NAME=GoJohnny
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
# Desenvolvimento local: SQLite
DATABASE_URL=sqlite:///./gojohnny.db

# Produção: Postgres via Railway (substituir pela URL gerada pelo Railway)
# DATABASE_URL=postgresql://user:password@host:port/gojohnny

# -----------------------------------------------------------------------------
# Autenticação JWT
# -----------------------------------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo para chat rápido (mais barato)
OPENAI_MODEL_CHAT=gpt-4o-mini

# Modelo para geração de planos e análises (mais capaz)
OPENAI_MODEL_COACH=gpt-4o

# Limite de tokens por resposta (custo)
OPENAI_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Observabilidade
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Sentry (opcional — para rastreio de erros em produção)
# Obtenha em: https://sentry.io/
SENTRY_DSN=

# -----------------------------------------------------------------------------
# CORS (quando houver frontend)
# -----------------------------------------------------------------------------
# Lista separada por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
