# GoJohnny — Variáveis de Ambiente
# Copie este arquivo para .env e configure com seus valores reais.
# Nunca commite valores sensíveis no repositório.

# ============================================================================
# BACKEND (FastAPI)
# ============================================================================

# Ambiente da aplicação: development | staging | production
APP_ENV=development

# Nome e versão da aplicação (para logs e diagnostics)
APP_NAME=GoJohnny
APP_VERSION=0.1.0

# Debug mode — desabilita documentação automática em produção
APP_DEBUG=true

# ============================================================================
# DATABASE
# ============================================================================

# Desenvolvimento local: SQLite (cria gojohnny.db na raiz)
DATABASE_URL=sqlite:///./gojohnny.db

# Produção: PostgreSQL via Railway
# DATABASE_URL=postgresql://user:password@host:5432/gojohnny

# ============================================================================
# SUPABASE AUTH (JWT validation)
# ============================================================================

# URL do seu projeto Supabase
# Obter em: https://app.supabase.com → Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Chave anon do Supabase (para frontend)
# Obter em: https://app.supabase.com → Settings > API > Anon Key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# OPENAI (Modelos de IA)
# ============================================================================

# Chave de API do OpenAI
# Obter em: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-...

# Modelo para chat interativo com o corredor
OPENAI_MODEL_CHAT=gpt-4o-mini

# Modelo para geração de planos de treino (mais complexo)
OPENAI_MODEL_COACH=gpt-4o

# Número máximo de tokens por resposta
OPENAI_MAX_TOKENS=2048

# ============================================================================
# LOGGING & OBSERVABILITY
# ============================================================================

# Nível de logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Sentry DSN para error tracking (opcional)
# Obter em: https://sentry.io
SENTRY_DSN=

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# URLs do frontend que podem acessar a API (separadas por vírgula)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# FRONTEND (Next.js)
# ============================================================================

# URL do projeto Supabase (mesma do backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anon do Supabase (pode ser exposta no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base da API do backend
# Desenvolvimento: http://localhost:8000
# Produção: https://seu-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
